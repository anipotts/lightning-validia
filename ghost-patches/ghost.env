# Lightning AI Studio config for Ghost
OPENAI_API_KEY=a84c7644-0d1b-453e-98ab-e95e4dd96d79/anipotts/fraud-model
OPENAI_BASE_URL=https://lightning.ai/api/v1

# Model mapping (Lightning AI available models)
TRIAGE_MODEL=openai/gpt-5-nano
DEEP_ANALYSIS_MODEL=openai/gpt-4o
SYNTHESIS_MODEL=openai/gpt-4o

# Database (docker-compose internal)
DATABASE_URL=postgresql+asyncpg://ghost:ghost@postgres:5432/ghost

# GitHub (optional, increases rate limits)
GITHUB_TOKEN=

# Slack alerts (optional)
SLACK_WEBHOOK_URL=

# Admin
ADMIN_API_KEY=

# Polling intervals
POLL_INTERVAL_CRITICAL=60
POLL_INTERVAL_HIGH=120
POLL_INTERVAL_MEDIUM=300
POLL_INTERVAL_LOW=900

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client"],
    "paths": {
      "@openproof/types/*": ["../../packages/types/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
